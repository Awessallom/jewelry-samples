# Создаём файл с ANSI/UTF-8 кодировкой
@"
# Python
__pycache__/
*.py[cod]
*.so
venv/
env/
.venv

# Database
*.db
*.sqlite
*.sqlite3

# IDE
.vscode/
.idea/
.DS_Store

# Testing
.pytest_cache/
.coverage/

# Logs
*.log
app.log

# Environment
.env

# Project specificdocker-compose up --build
test.db
samples.db
"@ | Out-File -FilePath .gitignore -Encoding utf8